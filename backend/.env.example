# Backend env template. Copy to .env.dev or .env.prod and set values.
# Do not commit real secrets.

# Core
APP_ENV=local
LOG_LEVEL=info
TZ=UTC

# Supabase / Database
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: direct Postgres URI if you need it
POSTGRES_CONNECTION_STRING=postgresql://user:pass@host:5432/dbname
SUPABASE_JWT_SECRET=your-jwt-secret

# LLM Providers
PROVIDER=azure_openai
OPENAI_API_KEY=
OPENAI_ORG=
OPENAI_BASE_URL=
AZURE_OPENAI_ENDPOINT=https://your-name.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Scheduler
SCHEDULE_POLL_INTERVAL_MS=30000
SCHEDULE_MAX_JOBS_PER_TICK=25

# Telemetry (optional)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
