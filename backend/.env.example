# Backend environment template (no secrets). Copy to `.env` and fill values.
# Do NOT commit real keys.

# Core
APP_ENV=local
LOG_LEVEL=info
TZ=UTC

# CORS (frontend dev origin)
CORS_ALLOW_ORIGINS=http://localhost:5173

# Supabase / DB
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUD=authenticated
# Optional: direct Postgres URI (not required; PostgREST is used by default)
POSTGRES_CONNECTION_STRING=

# Scheduler
SCHEDULE_POLL_INTERVAL_MS=30000
SCHEDULE_MAX_JOBS_PER_TICK=25
# Set to 1 to run scheduler thread inside API process (dev convenience)
SCHEDULER_IN_APP=0

# Surfer Docker Service (external)
SURFER_BASE_URL=http://127.0.0.1:8001
SURFER_API_KEY=
SURFER_POLL_INTERVAL_S=30
SURFER_MAX_WAIT_S=1800
SURFER_HEADLESS=1
SURFER_MAX_STEPS=3
# Dev-only: route to /api/explorer/mock when 1
SURFER_USE_MOCK=0

# LLM Provider (default Azure OpenAI)
PROVIDER=azure_openai
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=

# OpenAI native (optional alternative provider)
OPENAI_API_KEY=
OPENAI_ORG=
OPENAI_BASE_URL=

# Exa (search+contents for legacy/experiments)
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai

# Dev helper: optional test user token for worker contexts
DEV_TEST_USER_TOKEN=

# Note: The backend loads env from `.env` via DOTENV_PATH if set; otherwise it uses `.env` in CWD.
# DOTENV_PATH=backend/.env

