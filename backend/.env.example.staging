# Example staging environment (no secrets); copy to backend/.env.staging on the VM.

APP_ENV=staging
LOG_LEVEL=info
TZ=UTC

# CORS (staging frontend origin)
CORS_ALLOW_ORIGINS=https://staging.innernets.ai

# Supabase / DB (fill with real values on VM)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUD=authenticated
# Optional: direct Postgres URI for manual migrations
POSTGRES_CONNECTION_STRING=

# Scheduler
SCHEDULE_POLL_INTERVAL_MS=30000
SCHEDULE_MAX_JOBS_PER_TICK=25
SCHEDULER_IN_APP=0

# Surfer Docker Service (running on host at 127.0.0.1:8001)
# From inside Docker containers, use host.docker.internal to reach the host
SURFER_BASE_URL=http://host.docker.internal:8001
SURFER_API_KEY=
SURFER_POLL_INTERVAL_S=30
SURFER_MAX_WAIT_S=1800
SURFER_HEADLESS=1
SURFER_MAX_STEPS=3
SURFER_USE_MOCK=0

# LLM Provider (choose one)
PROVIDER=azure_openai
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=

# OpenAI native (optional alternative)
OPENAI_API_KEY=
OPENAI_ORG=
OPENAI_BASE_URL=

# Exa (optional)
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai

# Dev helper (optional)
DEV_TEST_USER_TOKEN=

