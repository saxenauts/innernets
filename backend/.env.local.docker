# Local Docker backend env (no secrets). Copy to backend/.env.local.docker and fill values.

APP_ENV=local
LOG_LEVEL=info
TZ=UTC

# Allow local Vite dev server
CORS_ALLOW_ORIGINS=http://localhost:5173

# Supabase (use your current project values)
SUPABASE_URL=https://YOUR_SUPABASE_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=***
SUPABASE_ANON_KEY=***
SUPABASE_JWT_SECRET=***
SUPABASE_JWT_AUD=authenticated
# Optional for manual migrations
POSTGRES_CONNECTION_STRING=

# Scheduler (keep in separate worker)
SCHEDULER_IN_APP=0
SCHEDULE_POLL_INTERVAL_MS=30000
SCHEDULE_MAX_JOBS_PER_TICK=25

# Surfer connectivity
# If you run Surfer locally on host 127.0.0.1:8001, containers reach it via host.docker.internal
SURFER_BASE_URL=http://host.docker.internal:8001
# For visible browser actions via Surfer service during dev
SURFER_HEADLESS=0

# LLM Provider (adjust as needed)
PROVIDER=azure_openai
AZURE_OPENAI_API_KEY=***
AZURE_OPENAI_ENDPOINT=https://YOUR_AZURE_OPENAI_ENDPOINT.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5

# Or OpenAI native
OPENAI_API_KEY=***
OPENAI_BASE_URL=

# Optional
EXA_API_KEY=***
DEV_TEST_USER_TOKEN=***
