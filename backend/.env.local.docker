# Local Docker backend env (no secrets). Copy to backend/.env.local.docker and fill values.

APP_ENV=local
LOG_LEVEL=info
TZ=UTC

# Allow local Vite dev server
CORS_ALLOW_ORIGINS=http://localhost:5173

# Supabase (use your current project values)
SUPABASE_URL=https://REDACTED_SUPABASE_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpiY3NiYXhtb3ZobGVhYXFyZmd0Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc1NjI0ODE5MSwiZXhwIjoyMDcxODI0MTkxfQ.XsHlB2Hm1IZ5wk_heFh6Fs_X32ukyEJQ0H1_Uev8lkk
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpiY3NiYXhtb3ZobGVhYXFyZmd0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTYyNDgxOTEsImV4cCI6MjA3MTgyNDE5MX0.phZiZX5PgMMC9uRL3NyvIGm0X1pQQjfsMPGj7zgNqZ8
