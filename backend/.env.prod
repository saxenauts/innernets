# Production placeholders (no secrets). Define via your deployment platform.

APP_ENV=prod
LOG_LEVEL=info
TZ=UTC

# Configure explicit CORS as needed (comma-separated)
CORS_ALLOW_ORIGINS=

# Use split processes (API and worker separately)
SCHEDULER_IN_APP=0

# Surfer should point to the production service URL
SURFER_BASE_URL=
SURFER_USE_MOCK=0

